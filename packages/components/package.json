{
  "name": "@riseaicloud/components",
  "version": "1.0.1",
  "description": "Edge Platform Domain Components (Layer 3)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@riseaicloud/tokens": "workspace:*",
    "@riseaicloud/ui": "workspace:*",
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^0.562.0",
    "recharts": "^3.1.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riseaicloud/edge-desgin.git",
    "directory": "packages/components"
  }
}
